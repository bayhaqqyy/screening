PORT=8088
DB_HOST=postgres
DB_PORT=5432
DB_USER=sahamscreen
DB_PASSWORD=your_secure_password_here
DB_NAME=sahamscreen
JWT_SECRET=your_super_secret_jwt_key
KAFKA_BROKER=kafka:29092
TV_WEBHOOK_PATH_TOKEN=your_webhook_path_token
TV_WEBHOOK_SECRET=your_webhook_secret
CLOUDFLARE_TUNNEL_TOKEN=

# Sprint 6 — optional schedule bypass for QA/testing.
# Format: "HH:MM:strategy,HH:MM:strategy" (strategy = swing|bsjp).
# When set, workers/schedule_worker.go fires the listed refreshes immediately
# on boot and skips the cron entries. Leave empty in production.
SCHEDULE_TIMES_OVERRIDE=

# AI integration — Groq free-tier OpenAI-compatible endpoint.
# Provider decision locked in PLAN_V2.md: two models chosen from Groq's
# free-tier quota table:
#   FAST — llama-3.1-8b-instant (14.4K req/day, 500K tok/day)
#   PRO  — meta-llama/llama-4-scout-17b-16e-instruct (1K req/day,
#          500K tok/day, MoE 17B × 16 experts for lower latency)
# Flip AI_ENABLED=true and populate GROQ_API_KEY to enable outbound calls.
AI_ENABLED=false
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_PRO_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TIMEOUT_MS=8000
GROQ_CACHE_TTL_SECONDS=120

# Per-user, per-endpoint rate limit for /api/ai/* routes. These are applied
# on top of the global IP-based limiter so logged-in users get isolated
# quotas. Values <=0 disable the limiter.
AI_RATE_LIMIT_PER_MIN=20
AI_RATE_LIMIT_BURST=5
