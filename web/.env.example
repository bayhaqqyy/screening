# SahamScreen Web — environment template.
# Copy to `.env` (gitignored) and populate for local dev, or feed into
# Vite via docker-compose. Any variable not prefixed with VITE_ is
# invisible to the frontend bundle, so the AI key stays server-side only.

# --- API wiring --------------------------------------------------------------
VITE_API_URL=http://localhost:8088/api
VITE_WS_URL=ws://localhost:8088/ws/stream

# --- Sprint 4/5 — redesigned table rollout -----------------------------------
# When true, Swing / Scalping / BSJP pages render the V2 layouts composed
# from components/screener/*. Default false until UX sign-off.
VITE_USE_TABLE_V2=false

# When true, the Watchlist page uses the V2 H+1..H+7 tracking table built
# in Sprint 4. Independent of VITE_USE_TABLE_V2 so we can ship the two
# redesigns on separate cadences.
VITE_USE_WATCHLIST_V2=false

# --- Sprint 7 — AI dark launch ----------------------------------------------
# Show AI commentary / analysis surfaces in the UI. The server still enforces
# its own AI_ENABLED flag, so flipping this true without also enabling the
# backend just produces "AI disabled" stubs — safe but not useful.
VITE_ENABLE_AI=false
